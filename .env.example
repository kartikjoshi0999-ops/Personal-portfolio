# ══════════════════════════════════════
# DATABASE (Supabase PostgreSQL)
# ══════════════════════════════════════
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ══════════════════════════════════════
# SUPABASE
# ══════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_JWT_SECRET="your-jwt-secret"

# ══════════════════════════════════════
# AI / OCR
# ══════════════════════════════════════
# Anthropic Claude (primary AI)
ANTHROPIC_API_KEY="sk-ant-..."

# Mathpix (math OCR) — free tier: 1000 calls/month
MATHPIX_APP_ID="your_app_id"
MATHPIX_APP_KEY="your_app_key"

# OpenAI (vision fallback + Whisper)
OPENAI_API_KEY="sk-..."

# ══════════════════════════════════════
# MARKET DATA (all have free tiers)
# ══════════════════════════════════════
# Alpha Vantage — free: 25 req/day
ALPHA_VANTAGE_API_KEY="your_key"

# Finnhub — free: 60 req/min
FINNHUB_API_KEY="your_key"

# Yahoo Finance — no key needed (unofficial)
# CoinGecko — free tier available
COINGECKO_API_KEY=""

# ══════════════════════════════════════
# PAYMENTS (Stripe)
# ══════════════════════════════════════
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_MONTHLY_PRICE_ID="price_..."
STRIPE_PRO_YEARLY_PRICE_ID="price_..."
STRIPE_LIFETIME_PRICE_ID="price_..."

# ══════════════════════════════════════
# BANKING (Plaid) — sandbox is free
# ══════════════════════════════════════
PLAID_CLIENT_ID="your_client_id"
PLAID_SECRET="your_sandbox_secret"
PLAID_ENV="sandbox"   # sandbox | development | production

# ══════════════════════════════════════
# PUSH NOTIFICATIONS (OneSignal — free)
# ══════════════════════════════════════
ONESIGNAL_APP_ID="your_app_id"
ONESIGNAL_API_KEY="your_rest_api_key"

# ══════════════════════════════════════
# APP CONFIG
# ══════════════════════════════════════
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
JWT_SECRET="change-this-to-a-random-256-bit-secret"

# Encryption key for sensitive data (AES-256 → 32 bytes base64)
ENCRYPTION_KEY="base64-encoded-32-byte-key"
