{
  "expo": {
    "name": "SolveSphere AI",
    "slug": "solvesphere-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.solvesphere.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "SolveSphere AI uses the camera to scan math problems and receipts.",
        "NSPhotoLibraryUsageDescription": "SolveSphere AI needs access to photos to scan math problems and receipts.",
        "NSFaceIDUsageDescription": "SolveSphere AI uses Face ID to protect your financial data."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "ai.solvesphere.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563eb"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SolveSphere AI needs access to your photos to scan math problems and receipts."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "solvesphere",
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      },
      "supabaseUrl": "https://YOUR_PROJECT.supabase.co",
      "supabaseAnonKey": "YOUR_ANON_KEY"
    }
  }
}
